generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  BASICO
  CRECER
  PRO
  EMPRESARIAL
}

enum AddonType {
  WHATSAPP
  FACTURACION
  QR_BOLIVIA
  ECOMMERCE
  CONTABILIDAD
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum DiscountType {
  PORCENTAJE
  MONTO_FIJO
}

// =============================================
// TENANT
// =============================================

model Organization {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  phone            String?
  address          String?
  logoUrl          String?
  rfc              String?
  currency         String    @default("BOB")
  businessType     String    @default("GENERAL")
  plan             PlanType  @default(BASICO)
  planExpiresAt    DateTime?
  trialEndsAt      DateTime?
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // SIAT Bolivia — facturación electrónica
  nitEmisor        String?   // NIT de la empresa (9 dígitos)
  razonSocial      String?   // Nombre legal para facturas
  siatCuis         String?   // Código mensual del SIN
  siatCuisExpiresAt DateTime? // Fin de validez del CUIS
  siatCufd         String?   // Código diario del SIN
  siatCufdExpiresAt DateTime? // Fin de validez del CUFD
  siatNroFactura   Int       @default(0) // Último número de factura emitido
  siatCertExpiry   DateTime? // Vencimiento del certificado digital

  profiles        Profile[]
  categories      Category[]
  products        Product[]
  customers       Customer[]
  orders          Order[]
  suppliers       Supplier[]
  discounts       Discount[]
  activityLogs    ActivityLog[]
  auditLogs       AuditLog[]
  branches        Branch[]
  addons          OrgAddon[]
  waConversations WaConversation[]
  paymentRequests PaymentRequest[]
  invoices        Invoice[]
  qrPayments      QrPayment[]

  @@map("organizations")
}

// =============================================
// USUARIOS
// =============================================

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  organizationId String?
  name           String
  role           Role     @default(STAFF)
  branchId       String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orders       Order[]       @relation("StaffOrders")

  @@map("profiles")
}

// =============================================
// SUCURSALES
// =============================================

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profiles     Profile[]
  orders       Order[]

  @@map("branches")
}

// =============================================
// ADD-ONS
// =============================================

model OrgAddon {
  id             String    @id @default(cuid())
  organizationId String
  addon          AddonType
  active         Boolean   @default(true)
  stripeItemId   String?
  phoneNumberId  String?   // WhatsApp: Meta phone_number_id para routing multi-tenant
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, addon])
  @@map("org_addons")
}

// =============================================
// WHATSAPP
// =============================================

model WaConversation {
  id             String    @id @default(cuid())
  organizationId String
  phone          String
  waId           String?
  type           String    @default("user_initiated")
  messageCount   Int       @default(0)
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, openedAt])
  @@map("wa_conversations")
}

// =============================================
// INVENTARIO
// =============================================

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@map("categories")
}

model Product {
  id             String    @id @default(cuid())
  organizationId String
  categoryId     String?
  supplierId     String?
  name           String
  description    String?
  sku            String?
  barcode        String?
  unit           String?
  price          Decimal   @default(0) @db.Decimal(10, 2)
  cost           Decimal   @default(0) @db.Decimal(10, 2)
  stock          Int       @default(0)
  minStock       Int       @default(5)
  batchExpiry    DateTime?
  imageUrl        String?
  active          Boolean   @default(true)
  hasVariants     Boolean   @default(false)
  attributeSchema Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier     Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderItems   OrderItem[]
  variants     ProductVariant[]

  @@unique([organizationId, sku])
  @@map("products")
}

model ProductVariant {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  attributes     Json
  sku            String?
  stock          Int       @default(0)
  price          Decimal?  @db.Decimal(10, 2)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([organizationId, sku])
  @@index([productId, active])
  @@index([organizationId])
  @@map("product_variants")
}

// =============================================
// CLIENTES
// =============================================

model Customer {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  email          String?
  address        String?
  rfc            String?
  birthday       DateTime?
  loyaltyPoints  Int       @default(0)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@map("customers")
}

// =============================================
// PEDIDOS
// =============================================

model Order {
  id              String        @id @default(cuid())
  organizationId  String
  customerId      String?
  staffId         String?
  branchId        String?
  customerName    String
  status          OrderStatus   @default(PENDIENTE)
  paymentMethod   PaymentMethod @default(EFECTIVO)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  shippingAddress String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff        Profile?     @relation("StaffOrders", fields: [staffId], references: [id], onDelete: SetNull)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  invoice      Invoice?
  qrPayments   QrPayment[]

  @@map("orders")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  variantSnapshot Json?

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@map("order_items")
}

// =============================================
// PROVEEDORES
// =============================================

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contact        String?
  phone          String?
  email          String?
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@map("suppliers")
}

// =============================================
// DESCUENTOS
// =============================================

model Discount {
  id             String       @id @default(cuid())
  organizationId String
  code           String
  description    String?
  type           DiscountType
  value          Decimal      @db.Decimal(10, 2)
  active         Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@map("discounts")
}

// =============================================
// LOG DE ACTIVIDAD (feed simple, todos los planes)
// =============================================

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  userName       String
  action         String
  entity         String
  entityId       String?
  details        String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// =============================================
// SOLICITUDES DE PAGO (QR manual)
// =============================================

enum PaymentRequestStatus {
  PENDIENTE
  CONFIRMADO
  RECHAZADO
}

model PaymentRequest {
  id             String               @id @default(cuid())
  organizationId String
  plan           PlanType
  months         Int                  @default(1)
  amountBOB      Decimal              @db.Decimal(10, 2)
  reference      String?
  notes          String?
  status         PaymentRequestStatus @default(PENDIENTE)
  confirmedAt    DateTime?
  confirmedBy    String?
  createdAt      DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("payment_requests")
}

// =============================================
// AUDIT LOG (antes/despues JSON, solo EMPRESARIAL)
// =============================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ip             String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// =============================================

enum InvoiceStatus {
  PENDIENTE
  ENVIADO
  OBSERVADO
  ANULADO
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  orderId        String        @unique
  nroFactura     Int
  cufe           String?       // Código Único de Factura Electrónica (del SIN)
  cuis           String        // CUIS vigente al momento de emisión
  cufd           String        // CUFD vigente al momento de emisión
  nitEmisor      String
  nitReceptor    String        @default("99999999") // consumidor final si no tiene NIT
  razonReceptor  String
  status         InvoiceStatus @default(PENDIENTE)
  xmlData        String?       @db.Text // XML firmado enviado al SIN
  sinResponse    Json?         // Respuesta cruda del SIN/intermediario
  total          Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("invoices")
}

// =============================================
// PAGOS QR BOLIVIA
// =============================================

enum QrPaymentStatus {
  PENDIENTE
  PAGADO
  EXPIRADO
  CANCELADO
  FALLIDO
}

model QrPayment {
  id               String          @id @default(cuid())
  organizationId   String
  orderId          String
  provider         String          // "AGGREGATOR" | "QR_SWITCH" | "TIGO" | "BIPAGO"
  externalId       String          // ID asignado por el PSP
  qrPayload        String          @db.Text // string EMVCo para renderizar QR cliente
  qrImageUrl       String?         // URL imagen pre-renderizada (opcional)
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("BOB")
  status           QrPaymentStatus @default(PENDIENTE)
  expiresAt        DateTime
  paidAt           DateTime?
  payerInfo        Json?           // info enmascarada del pagador
  providerResponse Json?           // respuesta cruda del PSP
  webhookReceivedAt DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([organizationId, createdAt])
  @@index([orderId, status])
  @@index([status, expiresAt])
  @@map("qr_payments")
}
